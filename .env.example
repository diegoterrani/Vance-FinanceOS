# OpenRouter (server-side only). Powers document extraction in api/_llm.ts.
# Set this in Vercel Project Settings → Environment Variables. NEVER expose to
# the browser (no VITE_ prefix).
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
# Optional: override the primary model (default: nvidia/nemotron-3-ultra-550b-a55b:free)
# OPENROUTER_MODEL="openrouter/owl-alpha"

# Supabase (Track B). Client-side, safe to expose (RLS protects the data).
VITE_SUPABASE_URL="https://gltffiwkzdvsxruexklw.supabase.co"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_PUBLISHABLE_KEY"

# APP_URL: The URL where this app is hosted. Optional.
APP_URL="MY_APP_URL"
